diff --git a/crates/larql-router-protocol/Cargo.toml b/crates/larql-router-protocol/Cargo.toml
index a30effaa..d588d869 100644
--- a/crates/larql-router-protocol/Cargo.toml
+++ b/crates/larql-router-protocol/Cargo.toml
@@ -70,11 +70,10 @@ serde_json = { workspace = true }
 [build-dependencies]
 tonic-build = "0.13"
 
-# `protobuf-src` builds a fresh `protoc` via cmake. That works on Linux
-# and macOS but fails on the GitHub windows-latest runner — cmake links
-# against the debug UCRT and absl drops a pile of unresolved
-# `__imp_ceilf` / `__imp_modf` symbols. On Windows we expect `protoc`
-# to be on `PATH` (CI installs it via `arduino/setup-protoc`); the
-# build script falls back to that.
-[target.'cfg(not(windows))'.build-dependencies]
-protobuf-src = "2"
+# `protoc` is supplied by the build environment (Nix nativeBuildInputs
+# provide it; CI installs it via `arduino/setup-protoc`).  We do not
+# bundle `protobuf-src`: its cmake-built protoc fails to link against
+# the debug UCRT on the GitHub windows-latest runner (absl drops a
+# pile of unresolved `__imp_ceilf` / `__imp_modf` symbols), and under
+# Nix it would pull a redundant cmake build.  `tonic_build` discovers
+# `protoc` from the `PROTOC` env var or `PATH`.
diff --git a/crates/larql-router-protocol/build.rs b/crates/larql-router-protocol/build.rs
index 28aba5a5..4323d3ec 100644
--- a/crates/larql-router-protocol/build.rs
+++ b/crates/larql-router-protocol/build.rs
@@ -3,18 +3,9 @@
 // against the debug UCRT (see Cargo.toml), so `protoc` must be on
 // PATH — CI sets it via `arduino/setup-protoc`. `tonic_build` picks
 // up `protoc` from the `PROTOC` env var or PATH automatically.
-#[cfg(not(windows))]
-fn set_protoc() {
-    std::env::set_var("PROTOC", protobuf_src::protoc());
-}
-
-#[cfg(windows)]
-fn set_protoc() {
-    // No-op: rely on the system `protoc` discovered via PROTOC / PATH.
-}
-
 fn main() -> Result<(), Box<dyn std::error::Error>> {
-    set_protoc();
+    // PROTOC is provided by the Nix build (nativeBuildInputs:
+    // protobuf); tonic_build picks it up from the env / PATH.
     tonic_build::compile_protos("proto/grid.proto")?;
     tonic_build::compile_protos("proto/expert.proto")?;
     tonic_build::compile_protos("proto/shard.proto")?;
